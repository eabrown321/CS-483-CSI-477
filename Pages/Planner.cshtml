@page
@model PlannerModel
@{
    ViewData["Title"] = "Course Planner";
}

<div class="fade-in-up">
    <form id="antiForgeryForm" method="post">
        @Html.AntiForgeryToken()
    </form>

    <!-- Header -->
    <div class="welcome-banner mb-4">
        <div class="gold-tag">
            <i class="bi bi-calendar3" aria-hidden="true"></i>
            Course Planner
        </div>
        <h1 class="mb-1">@Model.StudentName.Split(' ')[0]'s Plan</h1>
        <p class="mb-0">@Model.Major</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        var alertClass = Model.StatusType switch
        {
            "success" => "alert-success",
            "error" => "alert-danger",
            "warning" => "alert-warning",
            _ => "alert-info"
        };
        var alertIcon = Model.StatusType switch
        {
            "success" => "bi-check-circle-fill",
            "error" => "bi-x-circle-fill",
            "warning" => "bi-exclamation-triangle-fill",
            _ => "bi-info-circle-fill"
        };
        <div class="alert @alertClass alert-dismissible fade show mb-4" role="alert">
            <i class="bi @alertIcon me-2" aria-hidden="true"></i>
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- 4-Year Grid -->
    <div class="section-header mb-3">
        <h6>
            <span class="section-icon"><i class="bi bi-calendar3" aria-hidden="true"></i></span>
            4-Year Degree Plan
        </h6>
        <span style="font-size:0.78rem; color:var(--slate-500);">
            <i class="bi bi-info-circle me-1"></i>
            Courses can only be dropped into semesters when they are offered
        </span>
    </div>

    <div class="row g-3 mb-4">
        @for (int i = 0; i < Model.Semesters.Count; i++)
        {
            var semester = Model.Semesters[i];
            var yearLabel = (i / 2) + 1;
            var isFall = semester.Term == "Fall";

            <div class="col-lg-6 fade-in-up fade-in-up-delay-@((i % 4) + 1)">
                <div class="card h-100 planner-semester-card"
                     style="border-top: 3px solid @(isFall ? "var(--navy)" : "var(--gold)") !important;">
                    <div class="card-header d-flex justify-content-between align-items-center @(isFall ? "" : "gold")">
                        <span>
                            <i class="bi bi-@(isFall ? "wind" : "brightness-high") me-2" aria-hidden="true"></i>
                            Year @yearLabel · @semester.Term @semester.Year
                        </span>
                        <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                            @semester.TotalCredits cr
                        </span>
                    </div>

                    <div class="card-body p-0 planner-drop-zone"
                         data-term="@semester.Term"
                         data-year="@semester.Year">
                        @if (semester.Courses.Any())
                        {
                            <table class="table mb-0" aria-label="@semester.Term @semester.Year courses">
                                <tbody>
                                    @foreach (var course in semester.Courses)
                                    {
                                        <tr style="@(course.IsCompleted ? "background:var(--slate-50);" : "")">
                                            <td style="padding:0.75rem 1.25rem; width:1%;">
                                                @if (course.IsCompleted)
                                                {
                                                    <span style="color:var(--success); font-size:1rem;" aria-label="Completed">
                                                        <i class="bi bi-check-circle-fill" aria-hidden="true"></i>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span style="color:var(--slate-300); font-size:1rem;" aria-hidden="true">
                                                        <i class="bi bi-circle"></i>
                                                    </span>
                                                }
                                            </td>

                                            <td style="padding:0.75rem 0.5rem 0.75rem 0;">
                                                <div style="font-weight:700; font-size:0.8rem; color:var(--navy); letter-spacing:0.02em;">
                                                    @course.CourseCode
                                                </div>
                                                <div style="font-size:0.78rem; color:var(--slate-500); line-height:1.3;">
                                                    @course.CourseName
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(course.TermsOffered))
                                                {
                                                    <div style="margin-top:0.2rem;">
                                                        <span style="font-size:0.68rem; background:var(--slate-100); color:var(--slate-500); padding:0.1rem 0.4rem; border-radius:4px;">
                                                            @course.TermsOffered
                                                        </span>
                                                    </div>
                                                }
                                            </td>

                                            <td style="padding:0.75rem 0.5rem; text-align:right; white-space:nowrap;">
                                                <span style="font-size:0.75rem; color:var(--slate-400);">
                                                    @course.CreditHours cr
                                                </span>
                                            </td>

                                            <td style="padding:0.75rem 1rem 0.75rem 0; text-align:right; white-space:nowrap;">
                                                @if (!course.IsCompleted && course.PlannedCourseID > 0)
                                                {
                                                    <div class="d-flex gap-1 justify-content-end">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-success"
                                                                onclick="showMarkCompleteModal(@course.PlannedCourseID, '@course.CourseCode')"
                                                                aria-label="Mark @course.CourseCode as complete"
                                                                title="Mark complete">
                                                            <i class="bi bi-check-lg"></i>
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-danger"
                                                                onclick="removePlannedCourse(@course.PlannedCourseID)"
                                                                aria-label="Remove @course.CourseCode"
                                                                title="Remove">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center py-4 planner-empty-drop" style="color:var(--slate-400); min-height:150px;">
                                <i class="bi bi-inbox" style="font-size:1.5rem; display:block; margin-bottom:0.4rem;" aria-hidden="true"></i>
                                <span class="d-none d-md-inline" style="font-size:0.8rem;">Drop courses here</span>
                                <span class="d-md-none" style="font-size:0.8rem;">No courses yet</span>
                            </div>
                        }
                    </div>

                    <div style="padding:0.625rem 1.25rem; background:var(--slate-50); border-top:1px solid var(--slate-100); font-size:0.75rem; color:var(--slate-500);">
                        @semester.Courses.Count course(s) · @semester.TotalCredits credit(s)
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Available Courses -->
    <div class="card mb-4 fade-in-up">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span>
                <i class="bi bi-collection me-2" aria-hidden="true"></i>Available Courses
            </span>
            @if (Model.AvailableCourses != null && Model.AvailableCourses.Rows.Count > 0)
            {
                <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                    @Model.AvailableCourses.Rows.Count courses
                </span>
            }
        </div>

        <!-- Desktop hint — hidden on mobile -->
        <div class="alert alert-warning mb-0 d-none d-md-block" style="border-radius:0; border-left:none; border-right:none; border-top:none; font-size:0.85rem;">
            <i class="bi bi-lightbulb-fill me-2" aria-hidden="true"></i>
            Drag a course and drop it into a semester. Courses can only be placed in semesters when they are offered.
            <span style="margin-left:0.5rem;">
                <span style="background:var(--gold-pale); color:var(--gold); font-size:0.72rem; padding:0.15rem 0.5rem; border-radius:4px; font-weight:600;">Fall</span>
                <span style="background:#e8f4ff; color:#1d4ed8; font-size:0.72rem; padding:0.15rem 0.5rem; border-radius:4px; font-weight:600; margin-left:0.25rem;">Spring</span>
                badges show when a course is offered.
            </span>
        </div>
        <!-- Mobile hint — shown only on small screens -->
        <div class="alert alert-info mb-0 d-md-none" style="border-radius:0; border-left:none; border-right:none; border-top:none; font-size:0.85rem;">
            <i class="bi bi-hand-index-thumb me-2" aria-hidden="true"></i>
            Tap <i class="bi bi-plus-lg"></i> next to a course to add it to a semester.
        </div>

        <div class="table-responsive">
            <table class="table mb-0" aria-label="Available courses">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Name</th>
                        <th>Cr</th>
                        <th class="d-none d-md-table-cell">Dept</th>
                        <th>Offered</th>
                        <th class="d-md-none"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AvailableCourses != null && Model.AvailableCourses.Rows.Count > 0)
                    {
                        @foreach (System.Data.DataRow row in Model.AvailableCourses.Rows)
                        {
                            var termsRaw = row["TypicalTermsOffered"]?.ToString() ?? "";
                            var courseName = row["CourseName"]?.ToString() ?? "";
                            var courseId = row["CourseID"]?.ToString() ?? "";
                            <tr class="planner-draggable-course"
                                draggable="true"
                                data-course-id="@courseId"
                                data-terms-offered="@termsRaw"
                                data-course-name="@courseName">
                                <td>
                                    <span style="font-weight:700; color:var(--navy); font-size:0.85rem;">
                                        @row["CourseCode"]
                                    </span>
                                </td>
                                <td style="font-size:0.875rem; color:var(--slate-700);">@courseName</td>
                                <td style="font-size:0.8rem; color:var(--slate-500);">@row["CreditHours"]</td>
                                <td class="d-none d-md-table-cell">
                                    <span class="badge-grade" style="background:var(--slate-100); color:var(--slate-600);">
                                        @row["Department"]
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(termsRaw))
                                    {
                                        var termList = termsRaw.Split(',').Select(t => t.Trim());
                                        foreach (var t in termList)
                                        {
                                            var bg = t.Equals("Fall", StringComparison.OrdinalIgnoreCase)
                                            ? "background:var(--gold-pale); color:var(--gold);"
                                            : t.Equals("Spring", StringComparison.OrdinalIgnoreCase)
                                            ? "background:#e8f4ff; color:#1d4ed8;"
                                            : "background:var(--slate-100); color:var(--slate-600);";
                                            <span style="@bg font-size:0.68rem; padding:0.15rem 0.5rem; border-radius:4px; font-weight:600; margin-right:2px;">@t</span>
                                        }
                                    }
                                    else
                                    {
                                        <span style="color:var(--slate-300); font-size:0.75rem;">—</span>
                                    }
                                </td>
                                <!-- Mobile tap button — hidden on desktop -->
                                <td class="d-md-none" style="text-align:right; padding-right:0.75rem; white-space:nowrap;">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary"
                                            onclick="showMobileAddModal('@courseId', this.closest('tr').dataset.courseName, '@termsRaw')"
                                            aria-label="Add @row["CourseCode"] to plan">
                                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:var(--slate-500);">
                                <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:0.5rem;" aria-hidden="true"></i>
                                No available courses found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tips -->
    <div class="card fade-in-up">
        <div class="card-body" style="padding:1.25rem 1.5rem;">
            <div class="section-header" style="margin-bottom:0.75rem; padding-bottom:0.75rem;">
                <h6>
                    <span class="section-icon"><i class="bi bi-lightbulb-fill" aria-hidden="true"></i></span>
                    Planning Tips
                </h6>
            </div>
            <div class="row g-2">
                <div class="col-md-6">
                    <ul class="mb-0" style="font-size:0.875rem; color:var(--slate-700); padding-left:1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
                        <li>Aim for 12–18 credits per semester (15 is typical)</li>
                        <li>Check prerequisites before planning courses</li>
                        <li>Fall-only courses cannot be placed in Spring semesters</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="mb-0" style="font-size:0.875rem; color:var(--slate-700); padding-left:1.25rem; display:flex; flex-direction:column; gap:0.4rem;">
                        <li>Balance difficult courses with easier ones each semester</li>
                        <li>Courses marked <i class="bi bi-check-circle-fill text-success"></i> are already completed</li>
                        <li>Term badges show when each course is offered</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Add Course Modal -->
    <div class="modal fade" id="mobileAddModal" tabindex="-1"
         aria-labelledby="mobileAddLabel" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0"
                 style="border-radius:16px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
                <div class="modal-header border-0"
                     style="background:var(--navy); color:white; padding:1.25rem 1.5rem;">
                    <h5 class="modal-title mb-0" id="mobileAddLabel" style="color:white; font-size:1rem;">
                        <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>Add to Plan
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p style="font-size:0.9rem; color:var(--slate-700); margin-bottom:1rem;">
                        Adding <strong id="mobileCourseName"></strong>. Choose a semester:
                    </p>
                    <div class="row g-2">
                        <div class="col-8">
                            <label class="form-label form-label-sm" for="mobileTerm">Term</label>
                            <select id="mobileTerm" class="form-select form-select-sm" aria-label="Select term">
                                <option value="Fall">Fall</option>
                                <option value="Spring">Spring</option>
                                <option value="Summer">Summer</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label form-label-sm" for="mobileYear">Year</label>
                            <input type="number" id="mobileYear" class="form-control form-control-sm"
                                   value="@DateTime.Now.Year" min="2020" max="2035" aria-label="Year" />
                        </div>
                    </div>
                    <div id="mobileTermWarning"
                         class="alert alert-warning mt-2 py-2 mb-0"
                         style="display:none; font-size:0.8rem;">
                        <i class="bi bi-exclamation-triangle me-1" aria-hidden="true"></i>
                        <span id="mobileTermWarningText"></span>
                    </div>
                </div>
                <div class="modal-footer border-0" style="background:var(--slate-100); padding:1rem 1.5rem;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="submitMobileAdd()">
                        <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>Add to Plan
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Mark Complete Modal -->
    <div class="modal fade" id="markCompleteModal" tabindex="-1"
         aria-labelledby="markCompleteLabel" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0"
                 style="border-radius:16px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
                <div class="modal-header border-0"
                     style="background:var(--success,#15803d); color:white; padding:1.25rem 1.5rem;">
                    <h5 class="modal-title mb-0" id="markCompleteLabel" style="color:white; font-size:1rem;">
                        <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>Mark Course Complete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <p style="font-size:0.9rem; color:var(--slate-700); margin-bottom:1rem;">
                        Mark <strong id="markCourseCode"></strong> as completed. Select the grade you received:
                    </p>
                    <select id="markGradeSelect" class="form-select" aria-label="Select grade">
                        <option value="A">A</option>
                        <option value="A-">A-</option>
                        <option value="B+" selected>B+</option>
                        <option value="B">B</option>
                        <option value="B-">B-</option>
                        <option value="C+">C+</option>
                        <option value="C">C</option>
                        <option value="C-">C-</option>
                        <option value="D+">D+</option>
                        <option value="D">D</option>
                        <option value="F">F</option>
                    </select>
                </div>
                <div class="modal-footer border-0" style="background:var(--slate-100); padding:1rem 1.5rem;">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" onclick="submitMarkComplete()">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Mark Complete
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<style>
    .planner-draggable-course {
        cursor: grab;
        transition: background-color 0.2s ease, opacity 0.2s ease;
    }

        .planner-draggable-course:hover {
            background: var(--slate-50);
        }

        .planner-draggable-course.dragging {
            opacity: 0.4;
            cursor: grabbing;
        }

    .planner-drop-zone {
        min-height: 150px;
        position: relative;
        transition: background-color 0.15s ease;
    }

        .planner-drop-zone.drag-over {
            background: #eef6ff;
            outline: 2px dashed var(--navy);
            outline-offset: -6px;
        }

        .planner-drop-zone.drag-reject {
            background: #fff0f0;
            outline: 2px dashed var(--danger, #b91c1c);
            outline-offset: -6px;
        }

    @@keyframes shake {
        0%, 100% {
            transform: translateX(0);
        }

        20% {
            transform: translateX(-7px);
        }

        40% {
            transform: translateX(7px);
        }

        60% {
            transform: translateX(-4px);
        }

        80% {
            transform: translateX(4px);
        }
    }

    .planner-drop-zone.shake {
        animation: shake 0.4s ease;
    }

    .drop-error-toast {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        background: #b91c1c;
        color: white;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 0.35rem 0.9rem;
        border-radius: 6px;
        white-space: nowrap;
        z-index: 20;
        pointer-events: none;
        animation: fadeInToast 0.2s ease;
    }

    @@keyframes fadeInToast {
        from {
            opacity: 0;
            transform: translateX(-50%) translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
    }

    .semester-saving-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.85);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        border-radius: 4px;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const draggableCourses = document.querySelectorAll(".planner-draggable-course");
            const dropZones        = document.querySelectorAll(".planner-drop-zone");

            let draggedTermsOffered = "";

            draggableCourses.forEach(course => {
                course.addEventListener("dragstart", function (e) {
                    this.classList.add("dragging");
                    e.dataTransfer.setData("courseId",     this.dataset.courseId);
                    e.dataTransfer.setData("termsOffered", this.dataset.termsOffered || "");
                    draggedTermsOffered = this.dataset.termsOffered || "";
                    e.dataTransfer.effectAllowed = "move";
                });

                course.addEventListener("dragend", function () {
                    this.classList.remove("dragging");
                    draggedTermsOffered = "";
                    dropZones.forEach(z => z.classList.remove("drag-over", "drag-reject"));
                });
            });

            dropZones.forEach(zone => {
                zone.addEventListener("dragover", function (e) {
                    e.preventDefault();
                    const term  = this.dataset.term;
                    const valid = isTermValid(draggedTermsOffered, term);
                    this.classList.toggle("drag-over",  valid);
                    this.classList.toggle("drag-reject", !valid);
                    e.dataTransfer.dropEffect = valid ? "move" : "none";
                });

                zone.addEventListener("dragenter", function (e) {
                    e.preventDefault();
                });

                zone.addEventListener("dragleave", function (e) {
                    if (!this.contains(e.relatedTarget))
                        this.classList.remove("drag-over", "drag-reject");
                });

                zone.addEventListener("drop", function (e) {
                    e.preventDefault();
                    this.classList.remove("drag-over", "drag-reject");

                    const courseId    = e.dataTransfer.getData("courseId");
                    const termsOffered = e.dataTransfer.getData("termsOffered");
                    const term        = this.dataset.term;
                    const year        = this.dataset.year;

                    if (!isTermValid(termsOffered, term)) {
                        this.classList.add("shake");
                        this.addEventListener("animationend", () => this.classList.remove("shake"), { once: true });
                        showDropError(this, `Only offered in: ${termsOffered || "specific terms"}`);
                        return;
                    }

                    if (courseId && term && year) {
                        showSemesterSpinner(this);
                        submitAddCourse(courseId, term, year);
                    }
                });
            });
        });

        // ── Helpers ───────────────────────────────────────────────────
        function isTermValid(termsOffered, targetTerm) {
            if (!termsOffered || termsOffered.trim() === "") return true;
            const offered = termsOffered.split(",").map(t => t.trim().toLowerCase());
            return offered.includes(targetTerm.toLowerCase());
        }

        function showDropError(zone, message) {
            const existing = zone.querySelector(".drop-error-toast");
            if (existing) existing.remove();
            const toast = document.createElement("div");
            toast.className   = "drop-error-toast";
            toast.textContent = message;
            zone.appendChild(toast);
            setTimeout(() => { if (toast.parentNode) toast.remove(); }, 2500);
        }

        function showSemesterSpinner(zone) {
            if (zone.querySelector('.semester-saving-overlay')) return;
            const overlay = document.createElement('div');
            overlay.className = 'semester-saving-overlay';
            overlay.innerHTML = `
                <div style="display:flex; flex-direction:column; align-items:center; gap:0.5rem;">
                    <div style="width:28px; height:28px; border:3px solid rgba(13,34,64,0.15);
                                border-top-color:var(--navy); border-radius:50%;
                                animation:spin 0.7s linear infinite;"></div>
                    <span style="font-size:0.75rem; font-weight:600; color:var(--navy);">Saving…</span>
                </div>`;
            zone.appendChild(overlay);
        }

        function getAntiForgeryToken() {
            return document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;
        }

        function submitAddCourse(courseId, term, year) {
            const form = document.createElement("form");
            form.method = "post";
            form.action = "?handler=AddCourse";
            form.innerHTML = `
                <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                <input type="hidden" name="courseId" value="${courseId}" />
                <input type="hidden" name="term" value="${term}" />
                <input type="hidden" name="year" value="${year}" />`;
            document.body.appendChild(form);
            form.submit();
        }

        function removePlannedCourse(plannedCourseId) {
            const form = document.createElement("form");
            form.method = "post";
            form.action = "?handler=RemoveCourse";
            form.innerHTML = `
                <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                <input type="hidden" name="plannedCourseId" value="${plannedCourseId}" />`;
            document.body.appendChild(form);
            form.submit();
        }

        // ── Mark complete ─────────────────────────────────────────────
        let markCompleteId = 0;

        function showMarkCompleteModal(plannedCourseId, courseCode) {
            markCompleteId = plannedCourseId;
            document.getElementById('markCourseCode').textContent = courseCode;
            new bootstrap.Modal(document.getElementById('markCompleteModal')).show();
        }

        function submitMarkComplete() {
            const grade = document.getElementById('markGradeSelect').value;
            const form  = document.createElement('form');
            form.method = 'post';
            form.action = '?handler=MarkComplete';
            form.innerHTML = `
                <input type="hidden" name="__RequestVerificationToken" value="${getAntiForgeryToken()}" />
                <input type="hidden" name="plannedCourseId" value="${markCompleteId}" />
                <input type="hidden" name="grade" value="${grade}" />`;
            document.body.appendChild(form);
            form.submit();
        }

        // ── Mobile add modal ──────────────────────────────────────────
        let mobileCourseId     = 0;
        let mobileTermsOffered = "";

        function showMobileAddModal(courseId, courseName, termsOffered) {
            mobileCourseId     = courseId;
            mobileTermsOffered = termsOffered || "";
            document.getElementById('mobileCourseName').textContent = courseName;
            document.getElementById('mobileTermWarning').style.display = 'none';
            new bootstrap.Modal(document.getElementById('mobileAddModal')).show();
        }

        function submitMobileAdd() {
            const term = document.getElementById('mobileTerm').value;
            const year = document.getElementById('mobileYear').value;

            if (mobileTermsOffered && mobileTermsOffered.trim() !== "") {
                const offered = mobileTermsOffered.split(',').map(t => t.trim().toLowerCase());
                if (!offered.includes(term.toLowerCase())) {
                    document.getElementById('mobileTermWarningText').textContent =
                        `This course is only offered in: ${mobileTermsOffered}`;
                    document.getElementById('mobileTermWarning').style.display = 'block';
                    return;
                }
            }

            submitAddCourse(mobileCourseId, term, year);
        }
    </script>
}
