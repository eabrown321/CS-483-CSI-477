@page
@model CS_483_CSI_477.Pages.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
    <style>
        .profile-hero {
            background: linear-gradient(135deg, var(--navy) 0%, #1a3a5c 100%);
            border-radius: 20px;
            padding: 2.5rem;
            color: white;
            margin-bottom: 2rem;
            position: relative;
            overflow: hidden;
        }

            .profile-hero::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                border: 1px solid rgba(200,146,42,0.15);
                pointer-events: none;
            }

        .profile-avatar {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold), #e0a830);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.25rem;
            color: white;
            font-weight: 700;
            border: 3px solid rgba(255,255,255,0.2);
            position: relative;
            cursor: pointer;
            overflow: hidden;
            flex-shrink: 0;
        }

            .profile-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: 50%;
            }

        .avatar-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.5);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.2s;
            font-size: 1.25rem;
        }

        .profile-avatar:hover .avatar-overlay {
            opacity: 1;
        }

        .profile-name {
            font-family: 'DM Serif Display', serif;
            font-size: 1.75rem;
            margin-bottom: 0.25rem;
        }

        .profile-meta {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.65);
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
            margin-top: 0.5rem;
        }

            .profile-meta span {
                display: flex;
                align-items: center;
                gap: 0.35rem;
            }

        .profile-stat-chips {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 1.5rem;
        }

        .profile-stat-chip {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            padding: 0.6rem 1.1rem;
            text-align: center;
            min-width: 90px;
        }

        .profile-stat-chip-value {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--gold);
            line-height: 1;
        }

        .profile-stat-chip-label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.55);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-top: 0.2rem;
        }

        .section-card {
            background: white;
            border-radius: 16px;
            border: 1px solid var(--slate-200);
            margin-bottom: 1.5rem;
            overflow: hidden;
        }

        .section-card-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--slate-100);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .section-card-title {
            font-weight: 700;
            color: var(--navy);
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0;
        }

        .section-card-body {
            padding: 1.5rem;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.25rem;
        }

        .info-item-label {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--slate-400);
            margin-bottom: 0.25rem;
        }

        .info-item-value {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--navy);
        }

        .field-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--slate-600);
            text-transform: uppercase;
            letter-spacing: 0.07em;
            margin-bottom: 0.4rem;
        }

        .field-input {
            width: 100%;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            font-family: 'DM Sans', sans-serif;
            color: var(--navy);
            background: #f8fafc;
            transition: border-color 0.15s, box-shadow 0.15s;
            outline: none;
        }

            .field-input:focus {
                border-color: var(--navy);
                background: white;
                box-shadow: 0 0 0 3px rgba(13,34,64,0.09);
            }

        .field-row {
            margin-bottom: 1.1rem;
        }

        .btn-navy {
            background: var(--navy);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.65rem 1.5rem;
            font-size: 0.875rem;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

            .btn-navy:hover {
                background: #1a3a5c;
                transform: translateY(-1px);
            }

        .password-hint {
            font-size: 0.75rem;
            color: var(--slate-400);
            margin-top: 0.3rem;
        }

        .history-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

            .history-table th {
                text-align: left;
                padding: 0.6rem 1rem;
                font-size: 0.7rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.07em;
                color: var(--slate-400);
                background: #f8fafc;
                border-bottom: 1px solid var(--slate-100);
            }

            .history-table td {
                padding: 0.75rem 1rem;
                border-bottom: 1px solid #f1f5f9;
                color: var(--navy);
                vertical-align: middle;
            }

            .history-table tr:last-child td {
                border-bottom: none;
            }

        .badge-grade {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
        }

            .badge-grade.a {
                background: #dcfce7;
                color: #15803d;
            }

            .badge-grade.b {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .badge-grade.c {
                background: #fef9c3;
                color: #854d0e;
            }

            .badge-grade.d, .badge-grade.f {
                background: #fee2e2;
                color: #b91c1c;
            }

            .badge-grade.ip {
                background: #f1f5f9;
                color: #475569;
            }

        .badge-status {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
            font-size: 0.72rem;
            font-weight: 600;
        }

            .badge-status.completed {
                background: #dcfce7;
                color: #15803d;
            }

            .badge-status.in-progress {
                background: #dbeafe;
                color: #1d4ed8;
            }

        #avatar-upload {
            display: none;
        }
    </style>
}

<div class="profile-hero">
    <div class="d-flex align-items-start gap-3">
        <div>
            <label for="avatar-upload" title="Change photo">
                <div class="profile-avatar">
                    @if (!string.IsNullOrEmpty(Model.ProfilePhotoUrl))
                    {
                        <img src="@Model.ProfilePhotoUrl" alt="Profile photo" />
                    }
                    else
                    {
                        <span>@Model.Initials</span>
                    }
                    <div class="avatar-overlay">
                        <i class="bi bi-camera-fill text-white"></i>
                    </div>
                </div>
            </label>
            <form method="post" asp-page-handler="UploadPhoto" enctype="multipart/form-data" id="avatar-form">
                <input type="file" id="avatar-upload" name="PhotoFile" accept="image/*" onchange="document.getElementById('avatar-form').submit();" />
            </form>
        </div>
        <div>
            <div class="profile-name">@Model.FullName</div>
            <div class="profile-meta">
                <span><i class="bi bi-person-badge"></i> @Model.StudentIDNumber</span>
                <span><i class="bi bi-envelope"></i> @Model.Email</span>
                <span><i class="bi bi-mortarboard"></i> @Model.Major</span>
            </div>
            <div class="profile-stat-chips">
                <div class="profile-stat-chip">
                    <div class="profile-stat-chip-value">@Model.CurrentGPA.ToString("F2")</div>
                    <div class="profile-stat-chip-label">GPA</div>
                </div>
                <div class="profile-stat-chip">
                    <div class="profile-stat-chip-value">@Model.TotalCreditsEarned</div>
                    <div class="profile-stat-chip-label">Credits</div>
                </div>
                <div class="profile-stat-chip">
                    <div class="profile-stat-chip-value">@Model.EnrollmentYear</div>
                    <div class="profile-stat-chip-label">Enrolled</div>
                </div>
                <div class="profile-stat-chip">
                    <div class="profile-stat-chip-value">@Model.CourseCount</div>
                    <div class="profile-stat-chip-label">Courses</div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["ProfileSuccess"] != null)
{
    <div class="alert alert-success mb-3" style="border-radius:12px; font-size:0.875rem;">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["ProfileSuccess"]
    </div>
}
@if (TempData["ProfileError"] != null)
{
    <div class="alert alert-danger mb-3" style="border-radius:12px; font-size:0.875rem;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ProfileError"]
    </div>
}

<div class="row g-4">
    <!-- Left column -->
    <div class="col-lg-6">

        <!-- Account Info -->
        <div class="section-card">
            <div class="section-card-header">
                <h2 class="section-card-title"><i class="bi bi-person-circle"></i> Account Info</h2>
            </div>
            <div class="section-card-body">
                <div class="info-grid">
                    <div>
                        <div class="info-item-label">Student ID</div>
                        <div class="info-item-value">@Model.StudentIDNumber</div>
                    </div>
                    <div>
                        <div class="info-item-label">Full Name</div>
                        <div class="info-item-value">@Model.FullName</div>
                    </div>
                    <div>
                        <div class="info-item-label">Email</div>
                        <div class="info-item-value" style="word-break:break-all;">@Model.Email</div>
                    </div>
                    <div>
                        <div class="info-item-label">Major</div>
                        <div class="info-item-value">@(string.IsNullOrEmpty(Model.Major) ? "Undeclared" : Model.Major)</div>
                    </div>
                    <div>
                        <div class="info-item-label">Enrollment Status</div>
                        <div class="info-item-value">@Model.EnrollmentStatus</div>
                    </div>
                    <div>
                        <div class="info-item-label">Member Since</div>
                        <div class="info-item-value">@Model.CreatedAt.ToString("MMM yyyy")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Change Email -->
        <div class="section-card">
            <div class="section-card-header">
                <h2 class="section-card-title"><i class="bi bi-envelope"></i> Change Email</h2>
            </div>
            <div class="section-card-body">
                <form method="post" asp-page-handler="ChangeEmail">
                    <div class="field-row">
                        <label class="field-label" for="NewEmail">New Email Address</label>
                        <input type="email" id="NewEmail" name="NewEmail" class="field-input"
                               placeholder="new@email.com" value="@Model.Email" />
                    </div>
                    <div class="field-row">
                        <label class="field-label" for="EmailPassword">Current Password</label>
                        <input type="password" id="EmailPassword" name="CurrentPassword" class="field-input"
                               placeholder="Confirm your password" />
                    </div>
                    <button type="submit" class="btn-navy">
                        <i class="bi bi-check-lg"></i> Update Email
                    </button>
                </form>
            </div>
        </div>

    </div>

    <!-- Right column -->
    <div class="col-lg-6">

        <!-- Change Password -->
        <div class="section-card">
            <div class="section-card-header">
                <h2 class="section-card-title"><i class="bi bi-lock"></i> Change Password</h2>
            </div>
            <div class="section-card-body">
                <form method="post" asp-page-handler="ChangePassword">
                    <div class="field-row">
                        <label class="field-label" for="CurrentPassword">Current Password</label>
                        <input type="password" id="CurrentPassword" name="CurrentPassword" class="field-input"
                               placeholder="Your current password" />
                    </div>
                    <div class="field-row">
                        <label class="field-label" for="NewPassword">New Password</label>
                        <input type="password" id="NewPassword" name="NewPassword" class="field-input"
                               placeholder="At least 8 characters" />
                        <p class="password-hint">At least 8 characters</p>
                    </div>
                    <div class="field-row">
                        <label class="field-label" for="ConfirmNewPassword">Confirm New Password</label>
                        <input type="password" id="ConfirmNewPassword" name="ConfirmNewPassword" class="field-input"
                               placeholder="Repeat new password" />
                    </div>
                    <button type="submit" class="btn-navy">
                        <i class="bi bi-shield-lock"></i> Update Password
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<!-- Enrollment History -->
<div class="section-card mt-2">
    <div class="section-card-header">
        <h2 class="section-card-title"><i class="bi bi-clock-history"></i> Enrollment History</h2>
        <span style="font-size:0.8rem; color:var(--slate-400);">@Model.CourseHistory.Count course(s)</span>
    </div>
    @if (Model.CourseHistory.Count == 0)
    {
        <div class="section-card-body text-center" style="color:var(--slate-400); padding:2rem;">
            <i class="bi bi-inbox" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">No course history found.</p>
        </div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="history-table">
                <thead>
                    <tr>
                        <th>Course</th>
                        <th>Name</th>
                        <th>Credits</th>
                        <th>Term</th>
                        <th>Grade</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model.CourseHistory)
                    {
                        var gradeClass = course.Grade?.StartsWith("A") == true ? "a" :
                        course.Grade?.StartsWith("B") == true ? "b" :
                        course.Grade?.StartsWith("C") == true ? "c" :
                        course.Grade?.StartsWith("D") == true || course.Grade == "F" ? "d" : "ip";
                        var statusClass = course.Status == "Completed" ? "completed" : "in-progress";
                        <tr>
                            <td><strong>@course.CourseCode</strong></td>
                            <td>@course.CourseName</td>
                            <td>@course.CreditHours</td>
                            <td>@course.Term @course.AcademicYear</td>
                            <td>
                                @if (!string.IsNullOrEmpty(course.Grade) && course.Grade != "IP")
                                {
                                    <span class="badge-grade @gradeClass">@course.Grade</span>
                                }
                                else
                                {
                                    <span style="color:var(--slate-400);">—</span>
                                }
                            </td>
                            <td><span class="badge-status @statusClass">@course.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
