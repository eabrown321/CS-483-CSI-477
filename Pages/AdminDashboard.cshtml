@page
@model AdminDashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="fade-in-up">

    <!-- Header -->
    <div class="welcome-banner mb-4">
        <div class="gold-tag">
            <i class="bi bi-shield-lock-fill" aria-hidden="true"></i>
            Administration
        </div>
        <h1 class="mb-1">Admin Dashboard</h1>
        <p class="mb-0">Manage bulletins, documents, holds, and student records</p>
    </div>

    <!-- DB Status -->
    <div class="alert @(Model.IsConnected ? "alert-success" : "alert-danger") mb-4" role="alert">
        <i class="bi bi-@(Model.IsConnected ? "database-check" : "database-x") me-2" aria-hidden="true"></i>
        @(Model.IsConnected? Model.ConnectionMessage: Model.ErrorMessage)
    </div>

    @if (!string.IsNullOrEmpty(Model.UploadMessage))
    {
        <div class="alert @(Model.UploadSuccess ? "alert-success" : "alert-warning") mb-3" role="alert">
            <i class="bi bi-@(Model.UploadSuccess ? "check-circle" : "exclamation-triangle") me-2" aria-hidden="true"></i>
            @Model.UploadMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.HoldMessage))
    {
        <div class="alert @(Model.HoldSuccess ? "alert-success" : "alert-danger") mb-3" role="alert">
            <i class="bi bi-@(Model.HoldSuccess ? "check-circle" : "x-circle") me-2" aria-hidden="true"></i>
            @Model.HoldMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SearchMessage))
    {
        <div class="alert alert-info mb-3" role="alert">
            <i class="bi bi-info-circle me-2" aria-hidden="true"></i>
            @Model.SearchMessage
        </div>
    }

    <!-- Upload Cards -->
    <div class="row g-3 mb-4">

        <!-- Upload Bulletin -->
        <div class="col-lg-6 fade-in-up fade-in-up-delay-1">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-file-earmark-arrow-up me-2" aria-hidden="true"></i>Upload Bulletin PDF
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="UploadBulletin" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label" for="BulletinYear">
                                Academic Year <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="BulletinYear" id="BulletinYear"
                                   class="form-control" min="2020" max="2030"
                                   value="@Model.BulletinYear" required />
                            <div class="form-text">e.g. 2025 = 2025–2026 bulletin</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="BulletinCategory">
                                Category <span class="text-danger">*</span>
                            </label>
                            <select name="BulletinCategory" id="BulletinCategory" class="form-select" required>
                                <option value="Major" selected>Major Program</option>
                                <option value="Minor">Minor Program</option>
                                <option value="Core39">Core 39 / General Education</option>
                                <option value="General">General Catalog</option>
                            </select>
                            <div class="form-text">Minors are stored in a separate container</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="bulletinFile">
                                PDF File <span class="text-danger">*</span>
                            </label>
                            <input type="file" name="bulletinFile" id="bulletinFile"
                                   class="form-control" accept=".pdf" required />
                            <div class="form-text">Max 50 MB · PDF only</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="BulletinDescription">Description</label>
                            <input type="text" name="BulletinDescription" id="BulletinDescription"
                                   class="form-control"
                                   placeholder="e.g. 2025–2026 Official Undergraduate Bulletin" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-cloud-upload me-2" aria-hidden="true"></i>Upload Bulletin
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Upload Supporting Doc -->
        <div class="col-lg-6 fade-in-up fade-in-up-delay-2">
            <div class="card h-100">
                <div class="card-header gold">
                    <i class="bi bi-file-earmark-plus me-2" aria-hidden="true"></i>Upload Supporting Document
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="UploadDocument" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label" for="DocType">
                                Document Type <span class="text-danger">*</span>
                            </label>
                            <select name="DocType" id="DocType" class="form-select" required>
                                <option value="Syllabus">Syllabus</option>
                                <option value="Policy">Policy</option>
                                <option value="Advising Guide">Advising Guide</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="CourseCode">Course Code (if Syllabus)</label>
                            <input type="text" name="CourseCode" id="CourseCode"
                                   class="form-control" placeholder="e.g. CS 258" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="docFile">
                                File <span class="text-danger">*</span>
                            </label>
                            <input type="file" name="documentFile" id="docFile"
                                   class="form-control" accept=".pdf,.docx,.doc,.txt" required />
                            <div class="form-text">Max 50 MB · PDF / DOCX / DOC / TXT</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="DocDescription">Description</label>
                            <input type="text" name="DocDescription" id="DocDescription"
                                   class="form-control" placeholder="Brief description" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-cloud-upload me-2" aria-hidden="true"></i>Upload Document
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Bulletins Table -->
    <div class="card mb-4 fade-in-up">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span><i class="bi bi-journals me-2" aria-hidden="true"></i>Uploaded Bulletins</span>
            <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                @(Model.Bulletins?.Rows.Count ?? 0) file(s)
            </span>
        </div>
        @if (Model.Bulletins != null && Model.Bulletins.Rows.Count > 0)
        {
            var bulletinGroups = Model.Bulletins.Rows
            .Cast<System.Data.DataRow>()
            .GroupBy(r => r["BulletinCategory"].ToString())
            .OrderBy(g => g.Key);

            <div class="accordion" id="bulletinAccordion">
                @foreach (var group in bulletinGroups)
                {
                    var cat = group.Key ?? "Other";
                    var safeId = cat.Replace(" ", "").Replace("/", "");
                    var count = group.Count();
                    var (catBg, catColor) = cat switch
                    {
                        "Minor" => ("#dbeafe", "#1d4ed8"),
                        "Core39" => ("#fdf3e0", "#c8922a"),
                        "General" => ("#f1f5f9", "#475569"),
                        _ => ("#dcfce7", "#15803d")
                    };
                    <div class="accordion-item" style="border:none; border-bottom:1px solid var(--slate-100);">
                        <h2 class="accordion-header" id="heading-@safeId">
                            <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapse-@safeId"
                                    aria-expanded="false" aria-controls="collapse-@safeId"
                                    style="background:var(--slate-50); color:var(--navy); font-weight:600; font-size:0.875rem; padding:0.875rem 1.25rem; box-shadow:none;">
                                <span class="badge-grade me-2" style="background:@catBg; color:@catColor;">@cat</span>
                                <span style="color:var(--slate-500); font-weight:400; font-size:0.8rem;">@count file(s)</span>
                            </button>
                        </h2>
                        <div id="collapse-@safeId" class="accordion-collapse collapse"
                             aria-labelledby="heading-@safeId" data-bs-parent="#bulletinAccordion">
                            <div class="accordion-body p-0">
                                <table class="table mb-0" aria-label="@cat bulletins">
                                    <thead>
                                        <tr>
                                            <th>Year</th>
                                            <th>File Name</th>
                                            <th>Size</th>
                                            <th>Uploaded</th>
                                            <th>Description</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in group)
                                        {
                                            <tr>
                                                <td><span class="badge-grade" style="background:var(--slate-100); color:var(--navy);">@row["AcademicYear"]</span></td>
                                                <td style="font-size:0.85rem; color:var(--slate-700);">@row["FileName"]</td>
                                                <td style="font-size:0.8rem; color:var(--slate-500);">@((long.Parse(row["FileSize"].ToString()!) / 1024.0 / 1024.0).ToString("F1")) MB</td>
                                                <td style="font-size:0.8rem; color:var(--slate-500);">@(((DateTime)row["UploadDate"]).ToString("MM/dd/yyyy"))</td>
                                                <td style="font-size:0.8rem; color:var(--slate-500);">@row["Description"]</td>
                                                <td>
                                                    <form method="post" asp-page-handler="DeleteBulletin" class="d-inline">
                                                        <input type="hidden" name="id" value="@row["BulletinID"]" />
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('Delete this bulletin?')"
                                                                aria-label="Delete bulletin">
                                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5" style="color:var(--slate-500);">
                <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:0.5rem;" aria-hidden="true"></i>
                No bulletins uploaded yet.
            </div>
        }
    </div>

    <!-- Supporting Docs Table -->
    <div class="card mb-4 fade-in-up">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span><i class="bi bi-file-earmark-text me-2" aria-hidden="true"></i>Supporting Documents</span>
            <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                @(Model.Documents?.Rows.Count ?? 0) file(s)
            </span>
        </div>
        @if (Model.Documents != null && Model.Documents.Rows.Count > 0)
        {
            var docGroups = Model.Documents.Rows
            .Cast<System.Data.DataRow>()
            .GroupBy(r => r["DocumentType"].ToString())
            .OrderBy(g => g.Key);

            <div class="accordion" id="docAccordion">
                @foreach (var group in docGroups)
                {
                    var docType = group.Key ?? "Other";
                    var safeId = "doc-" + docType.Replace(" ", "").Replace("/", "");
                    var count = group.Count();
                    <div class="accordion-item" style="border:none; border-bottom:1px solid var(--slate-100);">
                        <h2 class="accordion-header" id="heading-@safeId">
                            <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#collapse-@safeId"
                                    aria-expanded="false" aria-controls="collapse-@safeId"
                                    style="background:var(--slate-50); color:var(--navy); font-weight:600; font-size:0.875rem; padding:0.875rem 1.25rem; box-shadow:none;">
                                <span class="badge-grade me-2" style="background:var(--slate-100); color:var(--slate-600);">@docType</span>
                                <span style="color:var(--slate-500); font-weight:400; font-size:0.8rem;">@count file(s)</span>
                            </button>
                        </h2>
                        <div id="collapse-@safeId" class="accordion-collapse collapse"
                             aria-labelledby="heading-@safeId" data-bs-parent="#docAccordion">
                            <div class="accordion-body p-0">
                                <table class="table mb-0" aria-label="@docType documents">
                                    <thead>
                                        <tr><th>File Name</th><th>Course</th><th>Size</th><th>Uploaded</th><th></th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in group)
                                        {
                                            <tr>
                                                <td style="font-size:0.85rem; color:var(--slate-700);">@row["DocumentName"]</td>
                                                <td style="font-size:0.8rem; color:var(--slate-500);">@(row["CourseCode"]?.ToString() is { Length: > 0 } cc ? cc : "—")</td>
                                                <td style="font-size:0.8rem; color:var(--slate-500);">@((long.Parse(row["FileSize"].ToString()!) / 1024.0 / 1024.0).ToString("F1")) MB</td>
                                                <td style="font-size:0.8rem; color:var(--slate-500);">@(((DateTime)row["UploadDate"]).ToString("MM/dd/yyyy"))</td>
                                                <td>
                                                    <form method="post" asp-page-handler="DeleteDocument" class="d-inline">
                                                        <input type="hidden" name="id" value="@row["DocumentID"]" />
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('Delete this document?')"
                                                                aria-label="Delete document">
                                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5" style="color:var(--slate-500);">
                <i class="bi bi-inbox" style="font-size:2rem; display:block; margin-bottom:0.5rem;" aria-hidden="true"></i>
                No documents uploaded yet.
            </div>
        }
    </div>

    <!-- ── Student Lookup ── -->
    <div class="card mb-4 fade-in-up">
        <div class="card-header">
            <i class="bi bi-person-search me-2" aria-hidden="true"></i>Student Lookup
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Search">
                <div class="row g-2 align-items-end">
                    <div class="col-md-9">
                        <label class="form-label" for="StudentId">Name, Student ID, or Email</label>
                        <input type="text" class="form-control" asp-for="StudentId"
                               id="StudentId" placeholder="e.g. Alex Thompson, 1001, or student@usi.edu" />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-2" aria-hidden="true"></i>Search
                        </button>
                    </div>
                </div>
            </form>

            @if (Model.StudentResults != null && Model.StudentResults.Rows.Count > 0)
            {
                <div class="table-responsive mt-3">
                    <table class="table mb-0" aria-label="Student search results">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Major</th>
                                <th style="text-align:center;">GPA</th>
                                <th style="text-align:center;">Credits</th>
                                <th style="text-align:center;">Status</th>
                                <th style="text-align:center;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in Model.StudentResults.Rows)
                            {
                                var sid = row["StudentID"].ToString();
                                <tr>
                                    <td style="font-size:0.85rem; color:var(--slate-500);">@sid</td>
                                    <td style="font-size:0.85rem; font-weight:600; color:var(--navy);">@row["StudentName"]</td>
                                    <td style="font-size:0.82rem; color:var(--slate-600);">@row["Email"]</td>
                                    <td style="font-size:0.82rem;">@row["Major"]</td>
                                    <td style="font-size:0.85rem; text-align:center;">@row["CurrentGPA"]</td>
                                    <td style="font-size:0.85rem; text-align:center;">@row["TotalCreditsEarned"]</td>
                                    <td style="text-align:center;">
                                        <span class="badge @(row["EnrollmentStatus"].ToString() == "Active" || row["EnrollmentStatus"].ToString() == "Full-Time" || row["EnrollmentStatus"].ToString() == "Part-Time" ? "bg-success" : "bg-secondary")"
                                              style="font-size:0.7rem;">
                                            @row["EnrollmentStatus"]
                                        </span>
                                    </td>
                                    <td style="text-align:center; white-space:nowrap;">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <a href="/AdminStudentProgress?studentId=@sid"
                                               class="btn btn-sm btn-outline-primary"
                                               title="View Progress" aria-label="View progress for @row["StudentName"]">
                                                <i class="bi bi-bar-chart-line" aria-hidden="true"></i>
                                            </a>
                                            <a href="/AdminStudentPlanner?studentId=@sid"
                                               class="btn btn-sm btn-outline-secondary"
                                               title="View Planner" aria-label="View planner for @row["StudentName"]">
                                                <i class="bi bi-calendar3" aria-hidden="true"></i>
                                            </a>
                                            <form method="post" asp-page-handler="ViewHolds" class="d-inline">
                                                <input type="hidden" name="studentId" value="@sid" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning"
                                                        title="Manage Holds" aria-label="Manage holds for @row["StudentName"]">
                                                    <i class="bi bi-shield-exclamation" aria-hidden="true"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- ── Account Hold Management ── -->
    @if (Model.ViewedStudentId > 0)
    {
        <div class="card mb-4 fade-in-up" id="holdPanel">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span>
                    <i class="bi bi-shield-exclamation me-2" aria-hidden="true"></i>
                    Account Holds —
                    @if (!string.IsNullOrEmpty(Model.ViewedStudentName))
                    {
                        <strong>@Model.ViewedStudentName</strong>
                    }
                    else
                    {
                        <span>Student #@Model.ViewedStudentId</span>
                    }
                </span>
            </div>
            <div class="card-body">

                <!-- Existing holds -->
                @if (Model.StudentHolds != null && Model.StudentHolds.Rows.Count > 0)
                {
                    <div class="mb-3">
                        <h6 style="font-size:0.85rem; font-weight:600; color:var(--navy); margin-bottom:0.75rem;">
                            Active Holds (@Model.StudentHolds.Rows.Count)
                        </h6>
                        <table class="table table-sm mb-0" aria-label="Active holds">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Reason</th>
                                    <th>Placed</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (System.Data.DataRow hold in Model.StudentHolds.Rows)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-danger" style="font-size:0.72rem;">
                                                @hold["HoldType"]
                                            </span>
                                        </td>
                                        <td style="font-size:0.85rem;">@hold["HoldReason"]</td>
                                        <td style="font-size:0.8rem; color:var(--slate-500);">
                                            @(hold["PlacedDate"] != DBNull.Value
                                                                            ? ((DateTime)hold["PlacedDate"]).ToString("MM/dd/yyyy")
                                                                            : "—")
                            </td>
                            <td>
                                <form method="post" asp-page-handler="RemoveHold" class="d-inline">
                                    <input type="hidden" name="holdId" value="@hold["HoldID"]" />
                                    <input type="hidden" name="studentId" value="@Model.ViewedStudentId" />
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Remove this hold?')"
                                            aria-label="Remove hold">
                                        <i class="bi bi-x-lg" aria-hidden="true"></i> Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-success py-2 mb-3" style="font-size:0.85rem;">
                        <i class="bi bi-check-circle me-2" aria-hidden="true"></i>
                        No active holds on this account.
                    </div>
                }

                <!-- Add new hold -->
                <h6 style="font-size:0.85rem; font-weight:600; color:var(--navy); margin-bottom:0.75rem;">
                    Add New Hold
                </h6>
                <form method="post" asp-page-handler="AddHold">
                    <input type="hidden" name="HoldStudentId" value="@Model.ViewedStudentId" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label form-label-sm" for="HoldType">Hold Type</label>
                            <select name="HoldType" id="HoldType" class="form-select form-select-sm" required>
                                <option value="Financial">Financial</option>
                                <option value="Academic">Academic</option>
                                <option value="Registration">Registration</option>
                                <option value="Library">Library</option>
                                <option value="Disciplinary">Disciplinary</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label form-label-sm" for="HoldReason">Reason</label>
                            <input type="text" name="HoldReason" id="HoldReason"
                                   class="form-control form-control-sm"
                                   placeholder="e.g. Unpaid balance of $500"
                                   maxlength="500" required />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-warning btn-sm w-100">
                                <i class="bi bi-shield-plus me-1" aria-hidden="true"></i>Add Hold
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
        document.querySelectorAll('input[type="file"]').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.files[0] && this.files[0].size > 50 * 1024 * 1024) {
                    alert('File exceeds 50 MB limit. Please choose a smaller file.');
                    this.value = '';
                }
            });
        });

        // Auto-scroll to hold panel if it's present
        document.addEventListener('DOMContentLoaded', function () {
            const holdPanel = document.getElementById('holdPanel');
            if (holdPanel) {
                holdPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    </script>
}
