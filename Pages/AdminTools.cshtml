@page
@model AdminToolsModel
@{
    ViewData["Title"] = "Admin Tools";
}

<div class="fade-in-up">

    <!-- Header -->
    <div class="welcome-banner mb-4">
        <div class="gold-tag">
            <i class="bi bi-tools" aria-hidden="true"></i>
            Admin Tools
        </div>
        <h1 class="mb-1">System Utilities</h1>
        <p class="mb-0">Administrative tools for managing course data and storage</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4 fade-in-up fade-in-up-delay-1">
            <div class="card h-100 admin-action-card">
                <div class="card-header">
                    <i class="bi bi-cloud-download me-2" aria-hidden="true"></i>Sync Azure Files
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="text-muted flex-grow-1" style="font-size:0.875rem;">
                        Scan Azure blob storage and import file records into the database.
                        Covers bulletins, minors, and certificates.
                    </p>
                    <a href="/SyncAzureFiles" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-repeat me-2" aria-hidden="true"></i>Sync Files
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 fade-in-up fade-in-up-delay-2">
            <div class="card h-100 admin-action-card">
                <div class="card-header gold">
                    <i class="bi bi-file-earmark-text me-2" aria-hidden="true"></i>Parse Bulletin Courses
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="text-muted flex-grow-1" style="font-size:0.875rem;">
                        Extract courses from all uploaded bulletins and populate the Courses table
                        with codes, names, and credit hours.
                    </p>
                    <a href="/ParseBulletinCourses" class="btn btn-primary w-100">
                        <i class="bi bi-lightning me-2" aria-hidden="true"></i>Parse Courses
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 fade-in-up fade-in-up-delay-3">
            <div class="card h-100 admin-action-card">
                <div class="card-header">
                    <i class="bi bi-bar-chart-line me-2" aria-hidden="true"></i>System Analytics
                </div>
                <div class="card-body d-flex flex-column">
                    <p class="text-muted flex-grow-1" style="font-size:0.875rem;">
                        View comprehensive system statistics, usage data, and analytics
                        across all students and courses.
                    </p>
                    <a href="/AdminAnalytics" class="btn btn-outline-primary w-100">
                        <i class="bi bi-graph-up me-2" aria-hidden="true"></i>View Analytics
                    </a>
                </div>
            </div>
        </div>
    </div>


</div>