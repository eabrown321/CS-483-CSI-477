@page
@model ParseBulletinCoursesModel
@{
    ViewData["Title"] = "Parse Bulletin Courses";
}

<div class="fade-in-up" style="max-width:800px; margin:0 auto;">

    <div class="section-header mb-4">
        <h5>
            <span class="section-icon"><i class="bi bi-file-earmark-text" aria-hidden="true"></i></span>
            Parse Bulletin Courses
        </h5>
        <a href="/AdminTools" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Back
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body" style="padding:1.5rem;">
            <p style="color:var(--slate-700); font-size:0.9rem; margin-bottom:1.25rem;">
                Scans all uploaded bulletins and extracts course data into the database.
                This process parses 221 bulletins and may take several minutes.
            </p>

            <div class="alert alert-warning mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                <strong>Warning:</strong> This process may take several minutes. Do not close or refresh the page.
            </div>

            <form method="post" data-ai-form>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-lightning me-2" aria-hidden="true"></i>Parse All Bulletins
                </button>
            </form>
        </div>
    </div>

    @if (Model.Results.Count > 0)
    {
        <div class="card fade-in-up">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span>
                    <i class="bi bi-check-circle me-2" aria-hidden="true"></i>Parse Results
                </span>
                <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem;">
                    @Model.BulletinsParsed parsed · @Model.TotalCoursesAdded added
                </span>
            </div>
            <div class="card-body p-0">
                <div style="max-height:500px; overflow-y:auto; padding:1.25rem;
                                font-family:'JetBrains Mono','Courier New',monospace;
                                font-size:0.78rem; line-height:1.6; color:var(--slate-700);
                                background:var(--slate-50);">
                    @foreach (var result in Model.Results)
                    {
                        <div style="padding:0.1rem 0; border-bottom:1px solid var(--slate-100);">
                            @result
                        </div>
                    }
                </div>
            </div>
        </div>
    }

</div>