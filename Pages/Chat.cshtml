@page
@model CS_483_CSI_477.Pages.ChatModel
@{
    ViewData["Title"] = "Advisor Chat";
}

<div class="fade-in-up">
    <div class="row g-3">
        <!-- Sidebar -->
        <div class="col-lg-4 col-xl-3">
            <div class="card h-100" style="min-height:720px;">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span>
                        <i class="bi bi-clock-history me-2" aria-hidden="true"></i>Chat History
                    </span>
                    <form method="post" asp-page-handler="NewChat" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-light">
                            <i class="bi bi-plus-lg me-1"></i>New
                        </button>
                    </form>
                </div>

                <div class="card-body p-2" style="overflow-y:auto; max-height:660px;">
                    @if (Model.Chats != null && Model.Chats.Count > 0)
                    {
                        @foreach (var chat in Model.Chats)
                        {
                            var isActive = chat.ChatId == Model.ChatId;
                            <div class="mb-2 p-2 rounded @(isActive ? "border border-primary" : "border")"
                                 style="background:@(isActive ? "rgba(13,110,253,0.06)" : "white");">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <form method="post" asp-page-handler="OpenChat" class="flex-grow-1">
                                        <input type="hidden" name="id" value="@chat.ChatId" />
                                        <button type="submit"
                                                class="btn btn-link text-start p-0 w-100"
                                                style="text-decoration:none; color:inherit;">
                                            <div style="font-weight:700; color:var(--navy); font-size:0.85rem;">
                                                @chat.Title
                                            </div>
                                            <div style="font-size:0.72rem; color:var(--slate-500);" class="mb-1">
                                                @chat.UpdatedAt.ToString("MMM d, h:mm tt")
                                            </div>
                                            <div style="font-size:0.76rem; color:var(--slate-600); line-height:1.35;">
                                                @(string.IsNullOrWhiteSpace(chat.Preview) ? "No messages yet." : chat.Preview)
                                            </div>
                                        </button>
                                    </form>

                                    <form method="post" asp-page-handler="DeleteChat"
                                          onsubmit="return confirm('Delete this chat?');">
                                        <input type="hidden" name="id" value="@chat.ChatId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete chat">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4" style="color:var(--slate-500);">
                            <i class="bi bi-chat-left-text" style="font-size:1.5rem; display:block; margin-bottom:0.5rem;"></i>
                            No saved chats yet.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Main Chat -->
        <div class="col-lg-8 col-xl-9">
            <div style="max-width:1000px; margin:0 auto;">
                <div class="section-header mb-3">
                    <h5>
                        <span class="section-icon"><i class="bi bi-robot" aria-hidden="true"></i></span>
                        AI Academic Advisor
                    </h5>
                    <div class="d-flex gap-2">
                        <form method="post" asp-page-handler="RemovePdf" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-secondary"
                                    aria-label="Remove uploaded PDF"
                                    @(string.IsNullOrEmpty(Model.PdfFileName) ? "disabled" : "")>
                                <i class="bi bi-file-earmark-x me-1" aria-hidden="true"></i>Remove PDF
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Clear" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-secondary"
                                    aria-label="Clear current chat"
                                    @(Model.Messages.Count == 0 ? "disabled" : "")>
                                <i class="bi bi-trash me-1" aria-hidden="true"></i>Clear Chat
                            </button>
                        </form>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mb-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                        @Model.ErrorMessage
                    </div>
                }

                @if (string.IsNullOrEmpty(Model.LoadedStudentSummary))
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        <i class="bi bi-person-x-fill" aria-hidden="true"></i>
                        Student data not loaded. Please ensure you are logged in with a valid student account.
                    </div>
                }

                <div class="card" style="border-radius:16px 16px 0 0 !important;">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div>
                            <i class="bi bi-chat-dots-fill me-2" aria-hidden="true"></i>
                            @(string.IsNullOrWhiteSpace(Model.CurrentChatTitle) ? "Conversation" : Model.CurrentChatTitle)
                        </div>
                        @if (!string.IsNullOrEmpty(Model.LoadedStudentSummary))
                        {
                            <span class="badge" style="background:rgba(255,255,255,0.2); font-size:0.7rem; font-weight:500;">
                                <i class="bi bi-person-check me-1" aria-hidden="true"></i>Student loaded
                            </span>
                        }
                    </div>

                    <div class="chat-messages" id="chatMessages" role="log" aria-live="polite" aria-label="Chat messages"
                         style="min-height:520px; max-height:520px; overflow-y:auto;">
                        @if (Model.Messages.Count == 0)
                        {
                            <div class="text-center py-5" style="color:var(--slate-500);">
                                <div style="width:64px; height:64px; background:var(--gold-pale); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; font-size:1.5rem; color:var(--gold);">
                                    <i class="bi bi-chat-dots" aria-hidden="true"></i>
                                </div>
                                <p class="fw-600 mb-1" style="color:var(--navy); font-weight:600;">Start a conversation</p>
                                <p class="small mb-0">Ask about courses, degree requirements, or academic planning.</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var message in Model.Messages)
                            {
                                <div class="message @message.Role" role="article" aria-label="@(message.Role == "user" ? "You" : "Advisor") at @message.Timestamp.ToString("h:mm tt")">
                                    <div class="msg-avatar" aria-hidden="true">
                                        @if (message.Role == "user")
                                        {
                                            <i class="bi bi-person-fill"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-robot"></i>
                                        }
                                    </div>
                                    <div>
                                        <div class="msg-bubble" style="white-space:pre-wrap;">@message.Content</div>
                                        <div class="msg-time">@message.Timestamp.ToString("h:mm tt")</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <form method="post" enctype="multipart/form-data" data-ai-form class="chat-input-area" id="chatForm">
                        <div class="mb-2">
                            <label for="UploadedPdf" class="form-label" style="font-size:0.75rem; margin-bottom:0.3rem;">
                                <i class="bi bi-paperclip me-1" aria-hidden="true"></i>Attach Academic Plan (PDF, optional)
                            </label>
                            <input type="file" asp-for="UploadedPdf" id="UploadedPdf" class="form-control form-control-sm" accept=".pdf"
                                   aria-describedby="pdfHelp" />
                            @if (!string.IsNullOrEmpty(Model.PdfFileName))
                            {
                                <div id="pdfHelp" class="small mt-1" style="color:var(--success);">
                                    <i class="bi bi-file-earmark-check me-1" aria-hidden="true"></i>
                                    <strong>@Model.PdfFileName</strong> attached
                                </div>
                            }
                        </div>

                        <div class="d-flex gap-0">
                            <input type="text"
                                   asp-for="UserMessage"
                                   id="userMessageInput"
                                   class="form-control"
                                   placeholder="Ask about courses, requirements, or planning…"
                                   autocomplete="off"
                                   style="border-radius:10px 0 0 10px; border-right:none;"
                                   aria-label="Type your message" />
                            <button type="submit" id="sendBtn" class="chat-send-btn" aria-label="Send message" disabled>
                                <i class="bi bi-send-fill" aria-hidden="true"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <div class="d-flex align-items-center justify-content-between mt-2 px-1">
                    <small style="color:var(--slate-500); font-size:0.75rem;">
                        <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                        AI-generated responses. Always verify with official academic sources.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var chatMessages = document.getElementById('chatMessages');
        if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;

        var userInput = document.getElementById('userMessageInput');
        var sendBtn = document.getElementById('sendBtn');

        function updateSendBtn() {
            if (userInput && sendBtn) {
                sendBtn.disabled = !userInput.value.trim();
            }
        }

        if (userInput) {
            userInput.addEventListener('input', updateSendBtn);
            window.addEventListener('load', function () {
                userInput.focus();
                updateSendBtn();
            });
        }

        var chatForm = document.getElementById('chatForm');
        if (chatForm) {
            chatForm.addEventListener('submit', function (e) {
                if (!userInput || !userInput.value.trim()) {
                    e.preventDefault();
                    return;
                }
                sendBtn.disabled = true;
                sendBtn.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span>';
            });
        }
    </script>
}