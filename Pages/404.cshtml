@page "/404"
@{
    ViewData["Title"] = "Page Not Found";
}

<div class="fade-in-up" style="max-width:560px; margin:4rem auto; text-align:center;">
    <div style="width:80px; height:80px; background:var(--gold-pale); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; font-size:2rem; color:var(--gold);">
        <i class="bi bi-compass" aria-hidden="true"></i>
    </div>

    <h1 style="color:var(--navy); font-family:'DM Serif Display', serif; font-size:4rem; margin-bottom:0;">404</h1>
    <h2 style="color:var(--navy); margin-bottom:0.5rem;">Page Not Found</h2>
    <p style="color:var(--slate-500); margin-bottom:2rem;">
        The page you're looking for doesn't exist or has been moved.
    </p>

    <div class="d-flex gap-3 justify-content-center">
        <a href="javascript:history.back()" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2" aria-hidden="true"></i>Go Back
        </a>
        <a href="/StudentDashboard" class="btn btn-primary">
            <i class="bi bi-house me-2" aria-hidden="true"></i>Dashboard
        </a>
    </div>
</div>